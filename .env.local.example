# Copy this file to .env.local and fill in your database URL.
# .env.local is gitignored — never commit real credentials.

# PostgreSQL connection string (required)
# Get this from your database provider dashboard:
#   Neon   → https://console.neon.tech  → Connection Details → Connection string
#   Supabase → Project Settings → Database → Connection string
#   Railway  → Your database → Connect → Connection URL
DATABASE_URL=postgresql://user:password@host:5432/dbname
